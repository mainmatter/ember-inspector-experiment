+++ b/dist/dev/packages/@ember/debug/inspect/identity.js
@@ -0,0 +1,46 @@
+import { ControllerMixin } from '../../controller/index.js';
+import CoreObject from '../../object/core.js';
+import MutableEnumerable from '../../enumerable/mutable.js';
+import { NativeArray } from '../../array/index.js';
+import MutableArray from '../../array/mutable.js';
+import EmberComponent from '../../component/index.js';
+import Evented from '../../object/evented.js';
+import PromiseProxyMixin from '../../object/promise-proxy-mixin.js';
+import EmberObject from '../../object/index.js';
+import Observable from '../../object/observable.js';
+
+const emberNames = new Map([
+  [Evented, 'Evented Mixin'],
+  [PromiseProxyMixin, 'PromiseProxy Mixin'],
+  [MutableArray, 'MutableArray Mixin'],
+  [MutableEnumerable, 'MutableEnumerable Mixin'],
+  [NativeArray, 'NativeArray Mixin'],
+  [Observable, 'Observable Mixin'],
+  [ControllerMixin, 'Controller Mixin'],
+  [CoreObject, 'CoreObject'],
+  [EmberObject, 'EmberObject'],
+  [EmberComponent, 'Classic Component'],
+]);
+
+export function objectIdentity(object) {
+  if (object instanceof Function) {
+    return 'Function:' + object.name;
+  }
+
+  if (object !== Object(object)) {
+    return typeof object;
+  }
+
+  if (Array.isArray(object)) {
+    return 'Array';
+  }
+
+  let className = '';
+  let { constructor } = object;
+
+  if (constructor) {
+    className = emberNames.get(constructor) || constructor.name;
+  }
+
+  return name || className || 'unknown';
+}
diff --git a/dist/dev/packages/@ember/debug/inspect/index.js b/dist/dev/packages/@ember/debug/inspect/index.js
